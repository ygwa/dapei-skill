{
  "name": "dapei-skill",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "esbuild engine/dapei-engine.ts --bundle --platform=node --format=esm --outfile=dist/dapei-engine.js --external:node:* --minify",
    "test": "npm run test:unit && npm run test:integration && npm run test:scenarios && npm run test:ai-behavior",
    "test:unit": "node --experimental-strip-types --test tests/unit/*.test.mjs",
    "test:integration": "node --experimental-strip-types --test tests/integration/*.test.mjs",
    "test:scenarios": "node --experimental-strip-types --test tests/scenarios/*.test.mjs",
    "test:ai-behavior": "node --experimental-strip-types --test tests/ai-behavior/*.test.mjs",
    "smoke": "bash scripts/smoke-test.sh",
    "verify": "npm run typecheck && npm run build && npm run test && npm run smoke"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.28.0",
    "js-yaml": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
