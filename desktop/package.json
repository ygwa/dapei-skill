{
  "name": "dapei-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "大培桌面端 — 独立 pnpm workspace",
  "scripts": {
    "postinstall": "node scripts/ensure-electron.mjs",
    "dev": "node scripts/ensure-electron.mjs && pnpm --filter @dapei/desktop-app dev",
    "build": "pnpm --filter @dapei/desktop-app build",
    "typecheck": "pnpm -r typecheck",
    "ensure-electron": "node scripts/ensure-electron.mjs"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
