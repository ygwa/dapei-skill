#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=scripts/lib/core.sh
source "$SCRIPT_ROOT/scripts/lib/core.sh"
# shellcheck source=scripts/commands/workspace.sh
source "$SCRIPT_ROOT/scripts/commands/workspace.sh"
# shellcheck source=scripts/commands/repos.sh
source "$SCRIPT_ROOT/scripts/commands/repos.sh"
# shellcheck source=scripts/commands/feature.sh
source "$SCRIPT_ROOT/scripts/commands/feature.sh"
# shellcheck source=scripts/commands/context.sh
source "$SCRIPT_ROOT/scripts/commands/context.sh"
# shellcheck source=scripts/commands/workflow.sh
source "$SCRIPT_ROOT/scripts/commands/workflow.sh"
# shellcheck source=scripts/commands/validation.sh
source "$SCRIPT_ROOT/scripts/commands/validation.sh"
# shellcheck source=scripts/commands/report.sh
source "$SCRIPT_ROOT/scripts/commands/report.sh"

usage() {
  cat <<'USAGE'
Usage:
  dapei init workspace

  dapei repos add <name> <git-url>
  dapei repos sync <name|--all>
  dapei repos list
  dapei repos analyze <name|--all>

  dapei create feature <name> --repos repo1,repo2 [--objective "..."]
  dapei context build <feature> [--stage <stage>]
  dapei run workflow <feature> --stage <stage>
  dapei validate feature <name>
  dapei review feature <name>
  dapei report feature <name>
  dapei close feature <name>
  dapei status feature
USAGE
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local args=("$@")
  if [[ "${args[0]:-}" == "@dapei" ]]; then
    args=("${args[@]:1}")
  fi

  if [[ ${#args[@]} -lt 2 ]]; then
    usage
    exit 1
  fi

  case "${args[0]} ${args[1]}" in
    "init workspace")
      init_workspace
      ;;
    "repos add")
      [[ ${#args[@]} -ge 4 ]] || die "usage: dapei repos add <name> <git-url>"
      repos_add "${args[2]}" "${args[3]}"
      ;;
    "repos sync")
      [[ ${#args[@]} -ge 3 ]] || die "usage: dapei repos sync <name|--all>"
      repos_sync "${args[2]}"
      ;;
    "repos list")
      repos_list
      ;;
    "repos analyze")
      [[ ${#args[@]} -ge 3 ]] || die "usage: dapei repos analyze <name|--all>"
      repos_analyze "${args[2]}"
      ;;
    "create feature")
      [[ ${#args[@]} -ge 3 ]] || die "missing feature name"
      local feature_name="${args[2]}"
      parse_create_feature_args "${args[@]:3}"
      [[ -n "$DAPEI_PARSED_REPOS" ]] || die "--repos is required"
      create_feature "$feature_name" "$DAPEI_PARSED_REPOS" "$DAPEI_PARSED_OBJECTIVE"
      ;;
    "context build")
      [[ ${#args[@]} -ge 3 ]] || die "usage: dapei context build <feature> [--stage <stage>]"
      local feature="${args[2]}"
      local stage="general"
      parse_stage_arg "${args[@]:3}"
      [[ -n "$DAPEI_PARSED_STAGE" ]] && stage="$DAPEI_PARSED_STAGE"
      context_build "$feature" "$stage"
      ;;
    "run workflow")
      [[ ${#args[@]} -ge 3 ]] || die "missing feature name"
      local feature="${args[2]}"
      local stage=""
      parse_stage_arg "${args[@]:3}"
      stage="$DAPEI_PARSED_STAGE"
      [[ -n "$stage" ]] || die "--stage is required"
      run_workflow_stage "$feature" "$stage"
      ;;
    "validate feature")
      [[ ${#args[@]} -ge 3 ]] || die "usage: dapei validate feature <name>"
      validate_feature "${args[2]}"
      ;;
    "review feature")
      [[ ${#args[@]} -ge 3 ]] || die "usage: dapei review feature <name>"
      feature_review "${args[2]}"
      ;;
    "report feature")
      [[ ${#args[@]} -ge 3 ]] || die "usage: dapei report feature <name>"
      report_feature "${args[2]}"
      ;;
    "close feature")
      [[ ${#args[@]} -ge 3 ]] || die "usage: dapei close feature <name>"
      close_feature "${args[2]}"
      ;;
    "status feature")
      feature_status
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
