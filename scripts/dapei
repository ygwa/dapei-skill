#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ROOT_DIR="${DAPEI_WORKSPACE_ROOT:-$(pwd)}"
WORKSPACE_DIR="$ROOT_DIR"
CODEBASE_DIR="$WORKSPACE_DIR/codebase"
FEATURES_DIR="$WORKSPACE_DIR/features"
DAPEI_DIR="$ROOT_DIR/.dapei"
SOURCE_DAPEI_DIR="$SCRIPT_ROOT/.dapei"
SOURCE_TEMPLATES_DIR="$SCRIPT_ROOT/dos/templates"
SOURCE_DOS_DIR="$SCRIPT_ROOT/dos"

usage() {
  cat <<'USAGE'
Usage:
  dapei init workspace
  dapei create feature <name> --repos repo1,repo2 [--objective "..."]
  dapei run workflow <feature> --stage <stage>
  dapei report feature <name>
  dapei codebase add <name> <git-url>
  dapei codebase sync <name>
  dapei codebase list
  dapei review feature <name>
  dapei status feature
USAGE
}

log() { echo "[dapei] $*"; }
err() { echo "[dapei][error] $*" >&2; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { err "missing command: $1"; exit 1; }
}

template_dir() {
  if [[ -d "$ROOT_DIR/dos/templates" ]]; then
    printf '%s\n' "$ROOT_DIR/dos/templates"
    return 0
  fi
  printf '%s\n' "$SOURCE_TEMPLATES_DIR"
}

is_effectively_empty_dir() {
  local dir="$1"
  [[ -z "$(find "$dir" -mindepth 1 -maxdepth 1 ! -name ".DS_Store" ! -name ".gitkeep" -print -quit 2>/dev/null)" ]]
}

is_conforming_workspace_dir() {
  local dir="$1"
  if [[ -d "$dir/.dapei" ]]; then
    return 0
  fi

  local count=0
  [[ -d "$dir/codebase" ]] && count=$((count + 1))
  [[ -d "$dir/docs" ]] && count=$((count + 1))
  [[ -d "$dir/features" ]] && count=$((count + 1))
  [[ $count -ge 2 ]]
}

copy_if_missing() {
  local source_path="$1"
  local target_path="$2"
  if [[ -e "$target_path" || ! -e "$source_path" ]]; then
    return 0
  fi
  mkdir -p "$(dirname "$target_path")"
  cp "$source_path" "$target_path"
}

feature_repo_names() {
  local feature_yaml="$1"
  awk '
    BEGIN { in_repos=0 }
    /^[[:space:]]+repos:[[:space:]]*$/ { in_repos=1; next }
    in_repos && /^[[:space:]]{2}[a-zA-Z0-9_-]+:[[:space:]]*.*$/ { in_repos=0 }
    in_repos {
      if (match($0, /name:[[:space:]]*"([^"]+)"/, m)) {
        print m[1]
      }
    }
  ' "$feature_yaml"
}

render_doc_template() {
  local template_path="$1"
  local output_path="$2"
  local date_value="$3"
  local objective_value="$4"
  local repos_value="$5"

  awk -v date="$date_value" -v objective="$objective_value" -v repos="$repos_value" '
    {
      gsub(/\{\{date\}\}/, date)
      gsub(/\{\{objective\}\}/, objective)
      if ($0 ~ /\{\{repos\}\}/) {
        print repos
        next
      }
      print
    }
  ' "$template_path" > "$output_path"
}

sanitize_stage_output_path() {
  local raw="$1"
  raw="$(echo "$raw" | sed -E 's/[[:space:]]*\(.*\)[[:space:]]*$//')"
  raw="$(echo "$raw" | xargs)"
  printf '%s\n' "$raw"
}

extract_stage_block() {
  local workflow_file="$1"
  local stage="$2"
  awk -v stage="$stage" '
    BEGIN { in_stage=0 }
    $0 ~ "^[[:space:]]*- id: " stage "$" { in_stage=1; next }
    in_stage && $0 ~ "^[[:space:]]*- id: " { exit }
    in_stage { print }
  ' "$workflow_file"
}

validate_stage_outputs() {
  local feature_dir="$1"
  local workflow_file="$2"
  local stage="$3"
  local missing=0
  local in_outputs=0
  local line raw_out output_path

  while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*outputs:[[:space:]]*$ ]]; then
      in_outputs=1
      continue
    fi
    if (( in_outputs == 0 )); then
      continue
    fi
    if [[ "$line" =~ ^[[:space:]]{2}[a-zA-Z_-]+:[[:space:]]*$ ]]; then
      break
    fi
    if [[ "$line" =~ ^[[:space:]]*-[[:space:]]+(.+)$ ]]; then
      raw_out="${BASH_REMATCH[1]}"
      output_path="$(sanitize_stage_output_path "$raw_out")"
      if [[ "$output_path" == "code changes" || "$output_path" == "all reports" || "$output_path" == "layered context" || "$output_path" == "feature manifest" ]]; then
        continue
      fi
      if [[ -n "$output_path" && ! -e "$feature_dir/$output_path" ]]; then
        err "stage '$stage' missing declared output: $output_path"
        missing=1
      fi
    fi
  done < <(extract_stage_block "$workflow_file" "$stage")

  return $missing
}

codebase_add() {
  local name="$1"
  local url="$2"

  if [[ -z "$name" || -z "$url" ]]; then
    err "usage: dapei codebase add <name> <git-url>"
    return 1
  fi

  local target="$CODEBASE_DIR/$name"
  local codebases_file="$DAPEI_DIR/codebases.yaml"

  if [[ -d "$target/.git" ]]; then
    err "codebase '$name' already exists"
    return 1
  fi

  mkdir -p "$CODEBASE_DIR"

  if [[ "$url" =~ ^https?:// ]]; then
    git clone "$url" "$target" || { err "clone failed"; return 1; }
  else
    git clone "$url" "$target" || { err "clone failed"; return 1; }
  fi

  if [[ ! -d "$target/.git" ]]; then
    err "clone failed for '$name'"
    return 1
  fi

  mkdir -p "$DAPEI_DIR"

  if [[ -f "$codebases_file" ]]; then
    if grep -q "name: $name" "$codebases_file" 2>/dev/null; then
      log "codebase '$name' already in registry"
    else
      local added_at
      added_at=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
      local default_branch
      default_branch=$(git -C "$target" rev-parse --abbrev-ref HEAD)
      cat >> "$codebases_file" <<EOF

  - name: $name
    path: $target
    url: $url
    added-at: $added_at
    default-branch: $default_branch
EOF
    fi
  else
    cat > "$codebases_file" <<EOF
version: "0.1"
codebases:
  - name: $name
    path: $target
    url: $url
    added-at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
    default-branch: $(git -C "$target" rev-parse --abbrev-ref HEAD)
EOF
  fi

  log "codebase '$name' added from $url"
}

codebase_sync() {
  local name="$1"

  if [[ -z "$name" ]]; then
    err "usage: dapei codebase sync <name>"
    return 1
  fi

  local target="$CODEBASE_DIR/$name"

  if [[ ! -d "$target/.git" ]]; then
    err "codebase '$name' not found. Run 'dapei codebase add' first."
    return 1
  fi

  log "syncing $name..."
  if ! git -C "$target" fetch origin; then
    err "fetch failed for '$name'"
    return 1
  fi
  local head
  head=$(git -C "$target" rev-parse --abbrev-ref HEAD)
  local hash
  hash=$(git -C "$target" rev-parse --short HEAD)
  log "codebase '$name' synced, $head at $hash"
}

codebase_list() {
  local codebases_file="$DAPEI_DIR/codebases.yaml"

  if [[ ! -f "$codebases_file" ]]; then
    echo "No codebases registered."
    return 0
  fi

  local count
  count=$(grep -c "name:" "$codebases_file" 2>/dev/null || echo 0)
  echo "📦 Codebases ($count):"

  while IFS= read -r line; do
    if [[ "$line" =~ name:\ * ]]; then
      local name
      name=$(echo "$line" | sed 's/.*name: *//' | tr -d ' ')
      if [[ -d "$CODEBASE_DIR/$name/.git" ]]; then
        local hash
        hash=$(git -C "$CODEBASE_DIR/$name" rev-parse --short HEAD 2>/dev/null || echo "???")
        local branch
        branch=$(git -C "$CODEBASE_DIR/$name" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "???")
        echo "  • $name - $branch ($hash)"
      else
        echo "  • $name - (not cloned)"
      fi
    fi
  done < "$codebases_file"
}

create_feature_branch() {
  local repo="$1"
  local feature="$2"

  local repo_path="$CODEBASE_DIR/$repo"
  if [[ ! -d "$repo_path/.git" ]]; then
    err "repo '$repo' not found in codebase"
    return 1
  fi

  local branch_name="feature/$feature"
  local base_ref
  base_ref=$(git -C "$repo_path" rev-parse HEAD)

  if git -C "$repo_path" checkout -b "$branch_name" 2>/dev/null; then
    echo "$base_ref"
    return 0
  else
    log "branch '$branch_name' already exists in '$repo'"
    echo "$base_ref"
    return 0
  fi
}

feature_review() {
  local feature="$1"
  local feature_dir="$FEATURES_DIR/$feature"

  if [[ ! -d "$feature_dir" ]]; then
    err "feature not found: $feature"
    return 1
  fi

  local feature_yaml="$feature_dir/feature.yaml"
  if [[ ! -f "$feature_yaml" ]]; then
    err "feature.yaml not found for $feature"
    return 1
  fi

  local report="$feature_dir/reports/daily-report.md"
  mkdir -p "$feature_dir/reports"

  local review_date
  review_date=$(date '+%Y-%m-%d %H:%M:%S %z')

  echo "# Daily Review: $feature" > "$report"
  echo "Date: $review_date" >> "$report"
  echo "" >> "$report"

  local last_review
  last_review=$(awk -F'"' '/^[[:space:]]*last-review-at:[[:space:]]*"/ { print $2 }' "$feature_yaml" | head -1 || true)

  while IFS= read -r repo; do
    [[ -z "$repo" ]] && continue
    local repo_path="$CODEBASE_DIR/$repo"
    if [[ -d "$repo_path/.git" ]]; then
      echo "## Repo: $repo" >> "$report"
      echo "" >> "$report"

      local branch="feature/$feature"
      local base_ref
      base_ref=$(awk -v target="$repo" '
        BEGIN { in_repo=0 }
        $0 ~ "name: \"" target "\"" { in_repo=1; next }
        in_repo && /base-ref:/ {
          split($0, a, "\"")
          print a[2]
          exit
        }
      ' "$feature_yaml")

      if [[ -n "$last_review" ]]; then
        echo "### Commits since last review ($last_review)" >> "$report"
        git -C "$repo_path" log --since="$last_review" --oneline "$branch" 2>/dev/null | while IFS= read -r commit_line; do
          echo "- $commit_line" >> "$report"
        done
      else
        echo "### All commits on branch (no prior review)" >> "$report"
        git -C "$repo_path" log --oneline "$branch" 2>/dev/null | head -20 | while IFS= read -r commit_line; do
          echo "- $commit_line" >> "$report"
        done
      fi

      local diff_stats
      diff_stats=$(git -C "$repo_path" diff --stat "$base_ref..$branch" 2>/dev/null | tail -1 || echo "no diff")
      echo "" >> "$report"
      echo "**Changes:** \`$diff_stats\`" >> "$report"
      echo "" >> "$report"
    fi
  done < <(feature_repo_names "$feature_yaml")

  local review_ts
  review_ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  local tmp_file
  tmp_file="$(mktemp)"
  awk -v ts="$review_ts" '
    BEGIN { updated=0 }
    /^[[:space:]]*last-review-at:/ {
      print "  last-review-at: \"" ts "\""
      updated=1
      next
    }
    { print }
    END {
      if (!updated) {
        print "  last-review-at: \"" ts "\""
      }
    }
  ' "$feature_yaml" > "$tmp_file"
  mv "$tmp_file" "$feature_yaml"

  log "review report generated: $report"
}

feature_status() {
  local features_dir="$FEATURES_DIR"

  if [[ ! -d "$features_dir" ]]; then
    echo "No features found."
    return 0
  fi

  local count
  count=$(find "$features_dir" -mindepth 1 -maxdepth 1 -type d -not -name ".templates" | wc -l | xargs)
  echo "📋 Features ($count):"

  for feat_dir in "$features_dir"/*; do
    [[ ! -d "$feat_dir" ]] && continue
    [[ "$(basename "$feat_dir")" == ".templates" ]] && continue

    local feature="$(basename "$feat_dir")"
    local feature_yaml="$feat_dir/feature.yaml"

    echo "  🔵 $feature"

    if [[ -f "$feature_yaml" ]]; then
      while IFS= read -r line; do
        if [[ "$line" =~ name:\ \"([^\"]+)\" ]]; then
          local repo="${BASH_REMATCH[1]}"
          local repo_path="$CODEBASE_DIR/$repo"
          if [[ -d "$repo_path/.git" ]]; then
            local branch="feature/$feature"
            local head
            head=$(git -C "$repo_path" rev-parse --short "$branch" 2>/dev/null || echo "???")
            local base_ref
            base_ref=$(grep -A5 "name: \"$repo\"" "$feature_yaml" 2>/dev/null | grep "base-ref:" | head -1 | cut -d'"' -f2 | cut -c1-8)
            echo "    └── $repo - $branch ($base_ref...→$head)"
          fi
        fi
      done < "$feature_yaml"
    fi
  done
}

init_workspace() {
  if ! is_effectively_empty_dir "$ROOT_DIR" && ! is_conforming_workspace_dir "$ROOT_DIR"; then
    err "current directory is not empty and does not look like a dapei workspace: $ROOT_DIR"
    err "initialize dapei in an empty directory, or migrate this directory explicitly before running init."
    exit 1
  fi

  mkdir -p "$DAPEI_DIR/workflows" "$DAPEI_DIR/rules"
  mkdir -p "$CODEBASE_DIR" "$FEATURES_DIR"
  mkdir -p "$ROOT_DIR/docs/as-is" "$ROOT_DIR/docs/architecture" "$ROOT_DIR/docs/standards"
  mkdir -p "$ROOT_DIR/docs/workflows" "$ROOT_DIR/docs/decisions" "$ROOT_DIR/docs/glossary" "$ROOT_DIR/docs/feature-impact"
  mkdir -p "$ROOT_DIR/dos/templates" "$ROOT_DIR/dos/ai-rules"

  if [[ ! -f "$DAPEI_DIR/workspace.yaml" ]]; then
    local workspace_name
    workspace_name="$(basename "$ROOT_DIR")"
    cat > "$DAPEI_DIR/workspace.yaml" <<EOF_WORKSPACE
version: 0.1
workspace:
  name: $workspace_name
  root: .
  default_branch: main
  locale: zh-CN
  codebases_file: .dapei/codebases.yaml

repos:
  codebase_root: codebase
  managed_repos: []

context_loading:
  strategy: layered
  layers:
    - name: global
      priority: 10
      merge_policy: deny
      sources:
        - docs/standards
        - dos/ai-rules
    - name: workspace
      priority: 20
      merge_policy: append
      sources:
        - docs/as-is
        - docs/architecture
        - docs/workflows
    - name: domain
      priority: 30
      merge_policy: append
      sources:
        - docs/business
    - name: repo
      priority: 40
      merge_policy: append
      sources: []
    - name: feature
      priority: 50
      merge_policy: override
      sources:
        - features/<feature>/context
    - name: runtime
      priority: 60
      merge_policy: override
      sources:
        - features/<feature>/tasks

agent_runtime:
  default_profile: implementer
  profiles:
    - name: implementer
      responsibilities:
        - implement scoped tasks
        - respect architecture boundaries
    - name: reviewer
      responsibilities:
        - validate architecture and risks
        - produce findings report

quality_gates:
  guardrail_mode: report
  required_reports:
    - feature-progress
    - risk-summary
EOF_WORKSPACE
  fi
  copy_if_missing "$SOURCE_DAPEI_DIR/commands.yaml" "$DAPEI_DIR/commands.yaml"
  copy_if_missing "$SOURCE_DAPEI_DIR/feature.schema.yaml" "$DAPEI_DIR/feature.schema.yaml"
  copy_if_missing "$SOURCE_DAPEI_DIR/codebases.schema.yaml" "$DAPEI_DIR/codebases.schema.yaml"
  copy_if_missing "$SOURCE_DAPEI_DIR/workflows/feature-lifecycle.yaml" "$DAPEI_DIR/workflows/feature-lifecycle.yaml"
  copy_if_missing "$SOURCE_DAPEI_DIR/rules/api.yaml" "$DAPEI_DIR/rules/api.yaml"
  copy_if_missing "$SOURCE_DAPEI_DIR/rules/ddd.yaml" "$DAPEI_DIR/rules/ddd.yaml"
  copy_if_missing "$SOURCE_DAPEI_DIR/rules/layering.yaml" "$DAPEI_DIR/rules/layering.yaml"
  copy_if_missing "$SOURCE_DAPEI_DIR/rules/naming.yaml" "$DAPEI_DIR/rules/naming.yaml"

  if [[ -d "$SOURCE_TEMPLATES_DIR" ]]; then
    while IFS= read -r template_file; do
      copy_if_missing "$template_file" "$ROOT_DIR/dos/templates/$(basename "$template_file")"
    done < <(find "$SOURCE_TEMPLATES_DIR" -mindepth 1 -maxdepth 1 -type f | sort)
  fi

  if [[ -f "$SOURCE_DOS_DIR/ai-rules/README.md" ]]; then
    copy_if_missing "$SOURCE_DOS_DIR/ai-rules/README.md" "$ROOT_DIR/dos/ai-rules/README.md"
  fi

  if [[ ! -f "$ROOT_DIR/docs/agents.md" ]]; then
    cat > "$ROOT_DIR/docs/agents.md" <<'EOF_DOC'
# Workspace Agents

Use this workspace as the durable source of context.

- `codebase/` contains managed Git repositories.
- `docs/` contains current business, architecture, technology, standards, and decisions.
- `features/` contains feature-specific execution workspaces.

Feature work should start from `features/<feature>/agents.md` after the feature context pack is created.
EOF_DOC
  fi

  if [[ ! -f "$DAPEI_DIR/workspace.yaml" ]]; then
    err "missing $DAPEI_DIR/workspace.yaml; please sync repository baseline files first"
    exit 1
  fi

  log "workspace initialized at $WORKSPACE_DIR"
}

prompt_yes_no() {
  local prompt="$1"
  local ans
  read -r -p "$prompt [y/N]: " ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

repo_exists() {
  local repo="$1"
  [[ -d "$CODEBASE_DIR/$repo/.git" ]]
}

clone_repo_interactive() {
  local repo="$1"
  local target="$CODEBASE_DIR/$repo"

  if repo_exists "$repo"; then
    log "repo '$repo' already exists in codebase"
    return 0
  fi

  if ! prompt_yes_no "repo '$repo' not found. clone now?"; then
    err "repo '$repo' is required for mapping"
    return 1
  fi

  local remote_url
  read -r -p "remote git url for '$repo': " remote_url
  if [[ -z "$remote_url" ]]; then
    err "remote url is required"
    return 1
  fi

  require_cmd git

  mkdir -p "$CODEBASE_DIR"

  if [[ "$remote_url" =~ ^https?:// ]]; then
    local mode
    read -r -p "auth mode: 1) token 2) username/password 3) git prompt [default:3]: " mode
    mode="${mode:-3}"

    if [[ "$mode" == "1" ]]; then
      local username token
      read -r -p "git username: " username
      read -r -s -p "personal access token (hidden): " token
      echo
      GIT_ASKPASS="$(mktemp)"
      cat > "$GIT_ASKPASS" <<'ASKPASS'
#!/usr/bin/env bash
case "$1" in
  *Username*) echo "$DAPEI_GIT_USERNAME" ;;
  *Password*) echo "$DAPEI_GIT_PASSWORD" ;;
  *) echo "" ;;
esac
ASKPASS
      chmod 700 "$GIT_ASKPASS"
      DAPEI_GIT_USERNAME="$username" DAPEI_GIT_PASSWORD="$token" GIT_ASKPASS="$GIT_ASKPASS" GIT_TERMINAL_PROMPT=0 \
        git clone "$remote_url" "$target" || { rm -f "$GIT_ASKPASS"; return 1; }
      rm -f "$GIT_ASKPASS"
      log "cloned '$repo' into $target"
      return 0
    fi

    if [[ "$mode" == "2" ]]; then
      local username password
      read -r -p "git username: " username
      read -r -s -p "git password (hidden): " password
      echo
      GIT_ASKPASS="$(mktemp)"
      cat > "$GIT_ASKPASS" <<'ASKPASS'
#!/usr/bin/env bash
case "$1" in
  *Username*) echo "$DAPEI_GIT_USERNAME" ;;
  *Password*) echo "$DAPEI_GIT_PASSWORD" ;;
  *) echo "" ;;
esac
ASKPASS
      chmod 700 "$GIT_ASKPASS"
      DAPEI_GIT_USERNAME="$username" DAPEI_GIT_PASSWORD="$password" GIT_ASKPASS="$GIT_ASKPASS" GIT_TERMINAL_PROMPT=0 \
        git clone "$remote_url" "$target" || { rm -f "$GIT_ASKPASS"; return 1; }
      rm -f "$GIT_ASKPASS"
      log "cloned '$repo' into $target"
      return 0
    fi

    git clone "$remote_url" "$target"
    log "cloned '$repo' into $target"
    return 0
  fi

  git clone "$remote_url" "$target"
  log "cloned '$repo' into $target"
}

init_feature_files() {
  local feature="$1"
  local objective="$2"
  local feature_dir="$FEATURES_DIR/$feature"

  mkdir -p "$feature_dir"/{repos,docs,context,memory,tests/regression,reports,tasks}

  cat > "$feature_dir/context/business-context.md" <<'EOF_CTX'
# Business Context

Describe business constraints and expected outcomes.
EOF_CTX

  cat > "$feature_dir/context/architecture-context.md" <<'EOF_CTX'
# Architecture Context

Describe architecture boundaries and integration constraints.
EOF_CTX

  cat > "$feature_dir/context/repo-context.md" <<'EOF_CTX'
# Repo Context

Describe touched repositories and modules.
EOF_CTX

  cat > "$feature_dir/context/feature-context.md" <<EOF_CTX
# Feature Context

Feature: $feature
Objective: ${objective:-TBD}
EOF_CTX

  cat > "$feature_dir/context/constraints.md" <<'EOF_CTX'
# Constraints

- Do not break architecture layering.
- Keep changes scoped to this feature.
EOF_CTX

  cat > "$feature_dir/memory/decision-log.md" <<'EOF_MEM'
# Decision Log
EOF_MEM
  cat > "$feature_dir/memory/tradeoff.md" <<'EOF_MEM'
# Tradeoffs
EOF_MEM
  cat > "$feature_dir/memory/risk.md" <<'EOF_MEM'
# Risk Log
EOF_MEM
  cat > "$feature_dir/memory/open-questions.md" <<'EOF_MEM'
# Open Questions
EOF_MEM
  cat > "$feature_dir/memory/timeline.md" <<'EOF_MEM'
# Timeline
EOF_MEM

  cat > "$feature_dir/tasks/backlog.md" <<'EOF_TASK'
# Backlog
EOF_TASK
  cat > "$feature_dir/tasks/plan.md" <<'EOF_TASK'
# Plan
EOF_TASK

  cat > "$feature_dir/reports/feature-progress.md" <<'EOF_REP'
# Feature Progress

- Status: initialized
EOF_REP

  cat > "$feature_dir/reports/daily-report.md" <<'EOF_REP'
# Daily Report
EOF_REP

  cat > "$feature_dir/reports/architecture-review.md" <<'EOF_REP'
# Architecture Review
EOF_REP

  local current_date
  current_date=$(date '+%Y-%m-%d')
  local templates
  templates="$(template_dir)"
  local repos_summary=""
  if [[ -d "$feature_dir/repos" ]]; then
    while IFS= read -r repo_name; do
      if [[ -z "$repos_summary" ]]; then
        repos_summary="$repo_name"
      else
        repos_summary="$repos_summary, $repo_name"
      fi
    done < <(find "$feature_dir/repos" -mindepth 1 -maxdepth 1 -exec basename {} \; | sort)
  fi
  [[ -z "$repos_summary" ]] && repos_summary="none"

  render_doc_template "$templates/01-current-state.md.template" "$feature_dir/docs/01-current-state.md" "$current_date" "${objective:-TBD}" "$repos_summary"
  render_doc_template "$templates/02-gap-analysis.md.template" "$feature_dir/docs/02-gap-analysis.md" "$current_date" "${objective:-TBD}" "$repos_summary"
  render_doc_template "$templates/03-business-design.md.template" "$feature_dir/docs/03-business-design.md" "$current_date" "${objective:-TBD}" "$repos_summary"
  render_doc_template "$templates/04-technical-design.md.template" "$feature_dir/docs/04-technical-design.md" "$current_date" "${objective:-TBD}" "$repos_summary"
  render_doc_template "$templates/05-task-breakdown.md.template" "$feature_dir/docs/05-task-breakdown.md" "$current_date" "${objective:-TBD}" "$repos_summary"
  render_doc_template "$templates/06-acceptance.md.template" "$feature_dir/docs/06-acceptance.md" "$current_date" "${objective:-TBD}" "$repos_summary"

  cat > "$feature_dir/agents.md" <<EOF_AG
# Feature Agents

Feature: $feature
Objective: ${objective:-TBD}

## Roles

1. PM Agent: scope and acceptance.
2. Architect Agent: boundary and design review.
3. Implementer Agent: code changes and validation.
4. QA Agent: testing and regression analysis.
EOF_AG
}

write_feature_manifest() {
  local feature="$1"
  local repos_csv="$2"
  local objective="$3"
  local feature_dir="$FEATURES_DIR/$feature"

  IFS=',' read -r -a repos <<<"$repos_csv"

  {
    echo 'version: "0.2"'
    echo "feature:"
    echo "  name: \"$feature\""
    echo "  objective: \"${objective:-TBD}\""
    echo '  owner: "unassigned"'
    echo "  repos:"
    for r in "${repos[@]}"; do
      r="$(echo "$r" | xargs)"
      [[ -z "$r" ]] && continue
      local repo_path="$CODEBASE_DIR/$r"
      local base_ref="unknown"
      local base_time
      base_time="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
      if [[ -d "$repo_path/.git" ]]; then
        base_ref=$(git -C "$repo_path" rev-parse HEAD)
        base_time=$(git -C "$repo_path" log -1 --format="%aI" HEAD 2>/dev/null || echo "$(date -u +"%Y-%m-%dT%H:%M:%SZ")")
      fi
      echo "    - name: \"$r\""
      echo "      branch: \"feature/$feature\""
      echo "      base-ref: \"$base_ref\""
      echo "      base-time: \"$base_time\""
    done
    echo "  scope:"
    echo "    in: []"
    echo "    out: []"
    echo "  acceptance:"
    echo "    - \"define acceptance criteria\""
    echo '  risk_level: "medium"'
    echo "  dependencies: []"
    echo '  last-review-at: null'
  } > "$feature_dir/feature.yaml"
}

create_feature() {
  local name="$1"
  local repos_csv="$2"
  local objective="$3"

  if [[ ! "$name" =~ ^[a-z0-9-]+$ ]]; then
    err "feature name must match ^[a-z0-9-]+$"
    exit 1
  fi

  local feature_dir="$FEATURES_DIR/$name"
  if [[ -d "$feature_dir" ]]; then
    err "feature already exists: $name"
    exit 1
  fi

  IFS=',' read -r -a repos <<<"$repos_csv"
  if [[ ${#repos[@]} -eq 0 ]]; then
    err "--repos is required"
    exit 1
  fi

  mkdir -p "$feature_dir/repos"

  for repo in "${repos[@]}"; do
    repo="$(echo "$repo" | xargs)"
    [[ -z "$repo" ]] && continue

    if ! repo_exists "$repo"; then
      clone_repo_interactive "$repo"
    fi

    if [[ ! -d "$CODEBASE_DIR/$repo" ]]; then
      err "repo missing after clone attempt: $repo"
      exit 1
    fi

    ln -sfn "$CODEBASE_DIR/$repo" "$feature_dir/repos/$repo"
    create_feature_branch "$repo" "$name" || exit 1
    log "mapped repo: $repo"
  done

  init_feature_files "$name" "$objective"
  write_feature_manifest "$name" "$repos_csv" "$objective"

  log "feature workspace created: $feature_dir"
}

run_workflow_stage() {
  local feature="$1"
  local stage="$2"
  local feature_dir="$FEATURES_DIR/$feature"
  local workflow_file="$DAPEI_DIR/workflows/feature-lifecycle.yaml"

  if [[ ! -d "$feature_dir" ]]; then
    err "feature not found: $feature"
    exit 1
  fi

  if [[ ! -f "$workflow_file" ]]; then
    err "workflow file not found: $workflow_file"
    exit 1
  fi

  local stage_line
  stage_line=$(grep -n "^\s*- id: $stage$" "$workflow_file" | cut -d: -f1)
  if [[ -z "$stage_line" ]]; then
    err "stage '$stage' not found in workflow"
    exit 1
  fi

  local requires_line
  requires_line="$(extract_stage_block "$workflow_file" "$stage" | awk '/^[[:space:]]*requires:[[:space:]]*\[/ { print; exit }')"

  if [[ "$requires_line" =~ requires:\s*\[([^\]]*)\] ]]; then
    local requires_str="${BASH_REMATCH[1]}"
    if [[ -n "$requires_str" ]]; then
      IFS=',' read -r -a requires_array <<< "$requires_str"
      for req in "${requires_array[@]}"; do
        req="$(echo "$req" | xargs | tr -d '\"')"
        [[ -z "$req" ]] && continue
        local req_report="$feature_dir/reports/stage-$req.completed"
        if [[ ! -f "$req_report" ]]; then
          err "required stage '$req' not completed before running '$stage'"
          err "please complete '$req' first"
          exit 1
        fi
      done
    fi
  fi

  mkdir -p "$feature_dir/reports"

  {
    echo ""
    echo "## Stage: $stage"
    echo "- Time: $(date '+%Y-%m-%d %H:%M:%S %z')"
    echo "- Status: started"
  } >> "$feature_dir/reports/feature-progress.md"

  if ! validate_stage_outputs "$feature_dir" "$workflow_file" "$stage"; then
    {
      echo "- Status: failed"
      echo "- Reason: missing declared outputs"
    } >> "$feature_dir/reports/feature-progress.md"
    exit 1
  fi

  local marker_file="$feature_dir/reports/stage-$stage.completed"
  cat > "$marker_file" <<EOF_MARKER
stage: $stage
completed-at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
EOF_MARKER

  {
    echo "- Status: completed"
    echo "- Marker: reports/stage-$stage.completed"
  } >> "$feature_dir/reports/feature-progress.md"

  log "workflow stage completed: feature=$feature stage=$stage"
}

report_feature() {
  local feature="$1"
  local feature_dir="$FEATURES_DIR/$feature"

  if [[ ! -d "$feature_dir" ]]; then
    err "feature not found: $feature"
    exit 1
  fi

  local daily="$feature_dir/reports/daily-report.md"
  local arch="$feature_dir/reports/architecture-review.md"
  local guardrail_report="$feature_dir/reports/guardrail-report.md"

  "$ROOT_DIR/scripts/dapei-guardrail" "$feature" >/dev/null

  cat > "$daily" <<EOF_D
# Daily Report

- Feature: $feature
- Generated At: $(date '+%Y-%m-%d %H:%M:%S %z')
- Progress Source: reports/feature-progress.md
- Risks Source: memory/risk.md
- Open Questions Source: memory/open-questions.md
- Guardrail Source: reports/guardrail-report.md
EOF_D

  cat > "$arch" <<EOF_A
# Architecture Review

- Feature: $feature
- Generated At: $(date '+%Y-%m-%d %H:%M:%S %z')
- Guardrails:
  - layering: .dapei/rules/layering.yaml
  - ddd: .dapei/rules/ddd.yaml
  - api: .dapei/rules/api.yaml
  - naming: .dapei/rules/naming.yaml
- Mode: report (non-blocking)
- Guardrail Report: $guardrail_report
EOF_A

  log "report pack generated for feature: $feature"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  local args=("$@")
  if [[ "${args[0]:-}" == "@dapei" ]]; then
    args=("${args[@]:1}")
  fi

  if [[ ${#args[@]} -lt 2 ]]; then
    usage
    exit 1
  fi

  case "${args[0]} ${args[1]}" in
    "init workspace")
      init_workspace
      ;;

    "create feature")
      if [[ ${#args[@]} -lt 3 ]]; then
        err "missing feature name"
        exit 1
      fi
      local feature_name="${args[2]}"
      local repos=""
      local objective=""
      local i=3
      while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
          --repos)
            i=$((i + 1))
            repos="${args[$i]:-}"
            ;;
          --objective)
            i=$((i + 1))
            objective="${args[$i]:-}"
            ;;
          *)
            ;;
        esac
        i=$((i + 1))
      done
      if [[ -z "$repos" ]]; then
        err "--repos is required"
        exit 1
      fi
      create_feature "$feature_name" "$repos" "$objective"
      ;;

    "run workflow")
      if [[ ${#args[@]} -lt 3 ]]; then
        err "missing feature name"
        exit 1
      fi
      local feature="${args[2]}"
      local stage=""
      local i=3
      while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
          --stage)
            i=$((i + 1))
            stage="${args[$i]:-}"
            ;;
          *) ;;
        esac
        i=$((i + 1))
      done
      if [[ -z "$stage" ]]; then
        err "--stage is required"
        exit 1
      fi
      run_workflow_stage "$feature" "$stage"
      ;;

    "report feature")
      if [[ ${#args[@]} -lt 3 ]]; then
        err "missing feature name"
        exit 1
      fi
      report_feature "${args[2]}"
      ;;

    "codebase add")
      if [[ ${#args[@]} -lt 4 ]]; then
        err "usage: dapei codebase add <name> <git-url>"
        exit 1
      fi
      codebase_add "${args[2]}" "${args[3]}"
      ;;
    "codebase sync")
      if [[ ${#args[@]} -lt 3 ]]; then
        err "usage: dapei codebase sync <name>"
        exit 1
      fi
      codebase_sync "${args[2]}"
      ;;
    "codebase list")
      codebase_list
      ;;

    "review feature")
      if [[ ${#args[@]} -lt 3 ]]; then
        err "usage: dapei review feature <name>"
        exit 1
      fi
      feature_review "${args[2]}"
      ;;

    "status feature")
      feature_status
      ;;

    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
