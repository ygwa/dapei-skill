#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENGINE="$SCRIPT_ROOT/engine/dapei-engine.ts"

feature="${1:-}"
if [[ -z "$feature" ]]; then
  echo "Usage: dapei-guardrail <feature-name>" >&2
  exit 1
fi

export DAPEI_ENGINE_HOME="$SCRIPT_ROOT"
exec node --experimental-strip-types "$ENGINE" run --capability guardrail.run --input "{\"feature\":\"$feature\"}"
