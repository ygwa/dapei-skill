#!/usr/bin/env python3
import os
import sys
import re
import subprocess
from datetime import datetime

def load_simple_yaml(filepath):
    """
    A simple YAML parser that handles the basic structure of rules files
    without external dependencies.
    """
    if not os.path.exists(filepath):
        return {}
    
    data = {}
    current_rules = []
    current_rule = None
    in_rules_list = False
    in_check = False
    in_files = False
    in_patterns = False
    
    with open(filepath, 'r', encoding='utf-8') as f:
        for line in f:
            # Strip comments and whitespace
            line_clean = line.split('#')[0].strip()
            if not line_clean:
                continue
            
            raw_line = line.rstrip()
            indent = len(raw_line) - len(raw_line.lstrip())
            
            # Simple top-level fields
            if indent == 0:
                in_rules_list = False
                in_check = False
                in_files = False
                in_patterns = False
                if ':' in line_clean:
                    k, v = line_clean.split(':', 1)
                    data[k.strip()] = v.strip().strip('"').strip("'")
                continue
            
            # Rules list detection
            if line_clean.startswith('rules:'):
                in_rules_list = True
                data['rules'] = current_rules
                continue
            
            if in_rules_list:
                # Rule item start
                if line_clean.startswith('-'):
                    in_check = False
                    in_files = False
                    in_patterns = False
                    current_rule = {}
                    current_rules.append(current_rule)
                    line_clean = line_clean[1:].strip()
                
                if current_rule is not None:
                    if line_clean.startswith('check:'):
                        in_check = True
                        current_rule['check'] = {}
                        continue
                    
                    if in_check:
                        if line_clean.startswith('files:'):
                            in_files = True
                            current_rule['check']['files'] = []
                            continue
                        elif line_clean.startswith('patterns:'):
                            in_patterns = True
                            current_rule['check']['patterns'] = []
                            continue
                        
                        if in_files and line_clean.startswith('-'):
                            val = line_clean[1:].strip().strip('"').strip("'")
                            current_rule['check']['files'].append(val)
                            continue
                        elif in_patterns and line_clean.startswith('-'):
                            val = line_clean[1:].strip().strip('"').strip("'")
                            current_rule['check']['patterns'].append(val)
                            continue
                        
                        if ':' in line_clean:
                            k, v = line_clean.split(':', 1)
                            current_rule['check'][k.strip()] = v.strip().strip('"').strip("'")
                    else:
                        if ':' in line_clean:
                            k, v = line_clean.split(':', 1)
                            current_rule[k.strip()] = v.strip().strip('"').strip("'")
                            
    return data

def get_modified_files(workspace_root):
    """
    Returns files modified in git status.
    """
    try:
        res = subprocess.run(
            ['git', 'status', '--porcelain'],
            cwd=workspace_root,
            capture_output=True,
            text=True,
            check=True
        )
        files = []
        for line in res.stdout.splitlines():
            if line.strip():
                parts = line.strip().split(None, 1)
                if len(parts) > 1:
                    files.append(parts[1])
        return files
    except Exception:
        return []

def main():
    if len(sys.argv) < 2:
        print("Usage: dapei-guardrail <feature-name>")
        sys.exit(1)
        
    feature = sys.argv[1]
    workspace_root = os.environ.get('DAPEI_WORKSPACE_ROOT', os.getcwd())
    feature_dir = os.path.join(workspace_root, 'features', feature)
    
    if not os.path.isdir(feature_dir):
        print(f"[guardrail][error] feature not found: {feature}", file=sys.stderr)
        sys.exit(1)
        
    # Read workspace guardrail config
    workspace_yaml_path = os.path.join(workspace_root, '.dapei', 'workspace.yaml')
    guardrail_mode = "report" # fallback
    if os.path.exists(workspace_yaml_path):
        ws_data = load_simple_yaml(workspace_yaml_path)
        # Note: simplistic nested lookup for quality_gates.guardrail_mode
        # In workspace.yaml:
        # quality_gates:
        #   guardrail_mode: report
        with open(workspace_yaml_path, 'r') as f:
            content = f.read()
            mode_match = re.search(r'guardrail_mode:\s*["\']?([a-z]+)["\']?', content)
            if mode_match:
                guardrail_mode = mode_match.group(1)
                
    status = "PASS"
    findings = []
    
    # Load all rules files
    rules_dir = os.path.join(workspace_root, '.dapei', 'rules')
    rule_files = []
    if os.path.isdir(rules_dir):
        rule_files = [os.path.join(rules_dir, f) for f in os.listdir(rules_dir) if f.endswith('.yaml')]
    
    all_rules = []
    for rf in rule_files:
        rule_set = load_simple_yaml(rf)
        if 'rules' in rule_set:
            all_rules.extend(rule_set['rules'])
            
    # Always include baseline checks if rule files don't cover them
    # LAYER-002 baseline check
    if not os.path.exists(os.path.join(feature_dir, 'feature.yaml')):
        findings.append("LAYER-002 missing feature.yaml (Severity: high)")
        status = "FAIL"
        
    # Run YAML-defined rules
    modified_files = get_modified_files(workspace_root)
    
    for rule in all_rules:
        rid = rule.get('id', 'UNKNOWN')
        title = rule.get('title', '')
        severity = rule.get('severity', 'medium')
        message = rule.get('message', '')
        check = rule.get('check', {})
        ctype = check.get('type', '')
        
        failed = False
        
        if ctype == 'file-required':
            files_to_check = check.get('files', [])
            for f in files_to_check:
                # Replace placeholder
                f_resolved = f.replace('<feature>', feature)
                full_path = os.path.join(workspace_root, f_resolved)
                if not os.path.exists(full_path):
                    failed = True
                    break
                    
        elif ctype == 'folder-name-regex':
            regex_str = check.get('regex', '')
            if regex_str:
                if not re.match(regex_str, feature):
                    failed = True
                    
        elif ctype == 'path-deny':
            patterns = check.get('patterns', [])
            for p in patterns:
                # Simple glob to regex conversion
                # e.g., "codebase/**" -> "^codebase/.*"
                regex_pat = '^' + p.replace('**/', '.*').replace('**', '.*').replace('*', '[^/]*') + '$'
                for mf in modified_files:
                    if re.match(regex_pat, mf):
                        failed = True
                        break
                if failed:
                    break
                    
        elif ctype == 'evidence-required':
            ev_file = check.get('evidence_file', '')
            ev_file_resolved = ev_file.replace('<feature>', feature)
            full_path = os.path.join(workspace_root, ev_file_resolved)
            
            # If the evidence file does not exist, or does exist but is empty/doesn't contain condition
            condition = check.get('condition', '')
            if not os.path.exists(full_path):
                failed = True
            else:
                with open(full_path, 'r', encoding='utf-8') as f:
                    content = f.read()
                    if condition and condition not in content:
                        failed = True
                        
        elif ctype == 'glossary-match':
            # Check if glossary directory exists and features use it
            glossary_dir = os.path.join(workspace_root, check.get('source', 'docs/glossary'))
            # If glossary exists, warn if there are terms but feature docs don't refer to them
            # (Just a simple structural check for v0.2)
            if not os.path.isdir(glossary_dir):
                failed = False # skip if no glossary config yet
                
        if failed:
            findings.append(f"{rid} {title} - {message or 'failed rule check'} (Severity: {severity})")
            if severity in ['high', 'blocker']:
                status = "FAIL"
            elif status != "FAIL":
                status = "WARN"
                
    # Write Guardrail Report
    report_file = os.path.join(feature_dir, 'reports', 'guardrail-report.md')
    os.makedirs(os.path.dirname(report_file), exist_ok=True)
    
    with open(report_file, 'w', encoding='utf-8') as rf:
        rf.write("# Guardrail Report\n\n")
        rf.write(f"- Feature: {feature}\n")
        rf.write(f"- Mode: {guardrail_mode}\n")
        rf.write(f"- Status: {status}\n")
        rf.write(f"- Generated At: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n")
        rf.write("## Findings\n")
        if not findings:
            rf.write("- none\n")
        else:
            for f in findings:
                rf.write(f"- {f}\n")
                
    print(f"[guardrail] report generated: reports/guardrail-report.md (status: {status})")
    
    # If gate mode and status is FAIL, exit non-zero
    if guardrail_mode == "gate" and status == "FAIL":
        sys.exit(1)
    sys.exit(0)

if __name__ == '__main__':
    main()
